// illegal, [ro] applied by default in simple syntax
global state: State& $[ro];

// complex protection syntax (rw or ro depending on who is using (public or private))
global state: State& {
	pub [ro, ro&],
	[rw, rw&]
};

// simple protection syntax (rw for both public and private)
pub global other: Other $[rw];


// illegal, cannot mix syntaxes like this (notice the extra pub at the beginning)
pub global state: State& {
	pub [ro, ro&],
	[rw, rw&]
};